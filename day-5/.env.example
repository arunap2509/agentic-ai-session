GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-latest
# Explicit context caching (prompt-caching/) needs a model whose account
# grant includes createCachedContent - override if gemini-flash-latest 404s
# for your key (some pinned versions like gemini-2.5-flash can be blocked
# for newer keys even though the API still lists the capability).
GEMINI_CACHE_MODEL=gemini-flash-latest

# langchain-agent-evals/ only - get these from your Langfuse project settings
# (https://cloud.langfuse.com, or your self-hosted instance's URL for BASE_URL)
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
